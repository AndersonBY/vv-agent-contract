  "recovery_cases": [
    {
      "name": "durable_model_response_is_replayed",
      "entry": "model_succeeded",
      "policy": "require_reconciliation",
      "expected": {
        "decision": "replay",
        "model_calls": 0,
        "event": "operation_replayed"
      }
    },
    {
      "name": "durable_tool_result_is_replayed",
      "entry": "tool_succeeded",
      "policy": "require_reconciliation",
      "expected": {
        "decision": "replay",
        "tool_calls": 0,
        "event": "operation_replayed"
      }
    },
    {
      "name": "started_model_requires_reconciliation_by_default",
      "entry": "model_started",
      "policy": "require_reconciliation",
      "expected": {
        "persisted_state": "ambiguous",
        "status": "reconciliation_required",
        "interruption_reason": "resume_requires_reconciliation",
        "model_calls": 0,
        "duplicate_cost_risk": true
      }
    },
    {
      "name": "started_model_explicit_duplicate_risk_retry",
      "entry": "model_started",
      "policy": "retry_with_duplicate_risk",
      "expected": {
        "persisted_state": "planned",
        "model_calls": 1,
        "same_operation_id": true,
        "event": "model_retry_duplicate_risk"
      }
    },
    {
      "name": "started_supported_tool_retries_same_key",
      "entry": "tool_started",
      "policy": "retry_idempotent_only",
      "expected": {
        "persisted_state": "planned",
        "tool_calls": 1,
        "same_operation_id": true,
        "same_idempotency_key": true
      }
    },
    {
      "name": "started_unknown_tool_is_not_retried",
      "entry": "tool_unknown_idempotency",
      "policy": "retry_idempotent_only",
      "expected": {
        "persisted_state": "ambiguous",
        "status": "reconciliation_required",
        "tool_calls": 0
      }
    },
    {
      "name": "request_digest_mismatch_never_replays",
      "entry": "tool_succeeded",
      "reconstructed_request_digest": "dddddddddddddddddddddddddddddddddddddddddddddddddddddddddddddddd",
      "expected": {
        "status": "reconciliation_required",
        "tool_calls": 0,
        "replay_count": 0
      }
    }
  ],
