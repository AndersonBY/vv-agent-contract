{
  "contract": "operation_journal_v1",
  "version": 1,
  "enums": {
    "kinds": [
      "model",
      "tool"
    ],
    "states": [
      "planned",
      "started",
      "succeeded",
      "failed",
      "ambiguous"
    ],
    "idempotency_support": [
      "supported",
      "unsupported",
      "unknown"
    ],
    "reconciliation_decisions": [
      "defer",
      "retry",
      "replay_success",
      "record_failure",
      "abort"
    ]
  },
  "transition_rules": {
    "allowed": [
      [
        "planned",
        "started"
      ],
      [
        "started",
        "succeeded"
      ],
      [
        "started",
        "failed"
      ],
      [
        "started",
        "ambiguous"
      ],
      [
        "ambiguous",
        "planned"
      ],
      [
        "ambiguous",
        "succeeded"
      ],
      [
        "ambiguous",
        "failed"
      ]
    ],
    "terminal_receipts": [
      "succeeded",
      "failed"
    ],
    "cycle_commit_clears_committed_journals": true,
    "progress_write_preserves_active_claim": true,
    "request_digest_mismatch": "require_reconciliation"
  },
